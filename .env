# LMStudio本地LLM配置（OpenAI兼容协议）

# API基础URL - LMStudio默认端口为1234
BASE_URL=http://localhost:1234/v1
# BASE_URL=http://openrouter.ai/api/v1
# # 模型名称 - 在LMStudio中加载的模型名
MODEL=your-model-name-here
#MODEL=nvidia/nemotron-3-super-120b-a12b:free
# # API密钥 - LMStudio本地可以留空或使用任意字符串
API_KEY=lm-studio
#API_KEY=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
# 其他可选配置
TEMPERATURE=0.7
MAX_TOKENS=1000
