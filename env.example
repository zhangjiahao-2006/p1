# LMStudio本地LLM配置（OpenAI兼容协议）

# API基础URL - LMStudio默认端口为1234
BASE_URL=http://localhost:1234/v1

# 模型名称 - 在LMStudio中加载的模型名
MODEL=your-model-name-here

# API密钥 - LMStudio本地可以留空或使用任意字符串
API_KEY=lm-studio

# 其他可选配置
TEMPERATURE=0.7
MAX_TOKENS=1000

# AnythingLLM配置
# API密钥，从AnythingLLM的设置页面获取
ANYTHINGLLM_API_KEY=your-anythingllm-api-key
# 工作区标识，从AnythingLLM的工作区设置页面获取
ANYTHINGLLM_WORKSPACE_SLUG=your-workspace-slug
